# =========================================================================
# Skylink Bundlefasta Dashboard - Environment Variables Template
# Copy this file to .env.local and fill in the values.
# =========================================================================

# 1. NEXT.JS ENVIRONMENT
NEXT_PUBLIC_APP_URL=http://localhost:3000

# 2. SUPABASE CONFIGURATION
# Client publishable keys (safe to expose to client)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# Server-only secret key (Bypasses Row Level Security (RLS), KEEP SECRET!)
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# 3. DARAJA (M-PESA) API CONFIGURATION
# Environment: 'sandbox' or 'production'
DARAJA_ENVIRONMENT=sandbox

# Daraja portal credentials
DARAJA_CONSUMER_KEY=your-daraja-consumer-key
DARAJA_CONSUMER_SECRET=your-daraja-consumer-secret

# M-Pesa Shortcode (PayBill or Store number)
DARAJA_SHORTCODE=600997

# Lipa Na M-Pesa Passkey (Used for STK push / online checkout query)
DARAJA_PASSKEY=bfb279f9aa9bdbcf158e97dd71a467cd2e0c893059b10f78e6b72ada1ed2c919

# API username created on M-Pesa portal (for B2C, Reversal, Balance queries)
DARAJA_INITIATOR_NAME=your-initiator-username

# Encrypted credentials or raw initiator password configured on M-Pesa portal
DARAJA_INITIATOR_PASSWORD=your-initiator-password
